/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "r2uploader",
  "main": "src/index.js",
  "compatibility_date": "2025-03-03",
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "MY_BUCKET",
      "bucket_name": "",
      "preview_bucket_name": ""
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "",
      "database_id": ""
    }
  ],
  "asetts": {
    "directory": "./assets",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/image/*",
      "/thumb/*",
      "/upload"
    ]
  },
  "triggers": {
    "crons": [
      "0 1 * * *"
    ]
  }
}